{
  "name": "@brewica/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:dev": "docker compose -f infra/docker-compose.dev.yml up -d",
    "db:dev:down": "docker compose -f infra/docker-compose.dev.yml down",
    "db:dev:reset": "docker compose -f infra/docker-compose.dev.yml down -v && docker compose -f infra/docker-compose.dev.yml up -d",
    "db:prod": "docker compose -f infra/docker-compose.db.yml up -d",
    "db:prod:down": "docker compose -f infra/docker-compose.db.yml down",
    "prod:up": "docker compose -f infra/docker-compose.prod.yml up -d",
    "prod:down": "docker compose -f infra/docker-compose.prod.yml down",
    "prod:pull": "docker compose -f infra/docker-compose.prod.yml pull"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@nx/eslint": "^22.6.5",
    "@nx/eslint-plugin": "^22.6.5",
    "@nx/js": "^22.6.5",
    "@nx/nest": "^22.6.5",
    "@nx/next": "^22.6.5",
    "@nx/node": "^22.6.5",
    "@nx/vite": "^22.6.5",
    "@nx/web": "^22.6.5",
    "@nx/webpack": "^22.6.5",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "1.15.26",
    "@swc/helpers": "0.5.21",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "~4.1.0",
    "autoprefixer": "10.4.27",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "^22.6.5",
    "postcss": "8.5.10",
    "prettier": "^2.6.2",
    "prisma": "^7.7.0",
    "tailwindcss": "3.4.3",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "webpack-cli": "^5.1.4"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "libs/*"
  ],
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^7.7.0",
    "axios": "^1.6.0",
    "next": "~16.1.6",
    "openid-client": "^6.8.3",
    "react": "^19.0.0",
